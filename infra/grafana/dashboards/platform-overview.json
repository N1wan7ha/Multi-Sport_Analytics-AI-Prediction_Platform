{
  "id": null,
  "uid": "matchmind-platform-overview",
  "title": "MatchMind Platform Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Requests Per Second",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_method_total[5m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API 5xx Error Rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_view_method_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_view_method_total[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Celery Queue Depth",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "celery_queue_length",
          "legendFormat": "queue length"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Active Connections",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count)",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Memory Usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "bytes"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction Task Runtime (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_request_duration_seconds_bucket{view=~\".*Prediction.*\"}[5m])) by (le))",
          "legendFormat": "p95 seconds"
        }
      ]
    }
  ]
}
