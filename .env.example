# ============================================================
# MatchMind — Multi-Sport Prediction Platform
# Environment Variables | Copy to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ----------------------------
# Django
# ----------------------------
DJANGO_SECRET_KEY=your-very-secret-key-here-change-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DB_NAME=matchmind_db
DB_USER=matchmind_user
DB_PASSWORD=matchmind_pwd
DB_HOST=db
DB_PORT=5432

# ----------------------------
# Redis
# ----------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----------------------------
# Cricket APIs
# ----------------------------
CRICAPI_KEY=3e7324ce-b3a3-48f6-9591-5164b38f51db
CRICAPI_BASE_URL=https://api.cricapi.com/v1

CRICBUZZ_RAPIDAPI_KEY=99c4a70c66msh1afc8d1d442246dp105f9djsn9bb49a4b889c
CRICBUZZ_RAPIDAPI_HOST=cricbuzz-cricket2.p.rapidapi.com
CRICBUZZ_BASE_URL=https://cricbuzz-cricket2.p.rapidapi.com

# APILayer Odds/Therundown (catalog + sportsbook affiliate metadata)
APILAYER_API_KEY=
APILAYER_ODDS_BASE_URL=https://api.apilayer.com/odds
APILAYER_THERUNDOWN_BASE_URL=https://api.apilayer.com/therundown
APILAYER_PRIMARY_SPORT=cricket

# ----------------------------
# JWT Auth
# ----------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ----------------------------
# ML Engine
# ----------------------------
ML_MODEL_PATH=/app/ml_engine/artifacts/
ML_MODEL_VERSION=v1.0

# Optional vector-context augmentation (Weaviate)
ML_VECTOR_CONTEXT_ENABLED=False
ML_VECTOR_TOP_K=6
ML_VECTOR_MAX_PROB_SHIFT=0.06

WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=MatchContext
WEAVIATE_TIMEOUT_SECONDS=3

# ----------------------------
# Frontend (Angular) 
# ----------------------------
ANGULAR_API_URL=http://localhost:8000/api/v1

# ----------------------------
# Monitoring
# ----------------------------
PROMETHEUS_ENABLED=True
